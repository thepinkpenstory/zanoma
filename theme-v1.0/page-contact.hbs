{{!< default}}

<section class="page-hero">
<div class="container">
<h1>Get In <span class="highlight">Touch</span></h1>
<p class="hero-sub">Tell us about your brand and we'll show you how AI can help.</p>
</div>
</section>

<section class="content-section">
<div class="container">
<div class="content-grid">
<div class="svccard" style="padding:40px">
<h2 style="margin-bottom:24px">Send us a message</h2>
<form action="https://formspree.io/f/kevinkeranen@gmail.com" method="POST" style="display:grid;gap:20px">
<div>
<label style="display:block;font-size:13px;color:var(--text-muted);margin-bottom:6px">Name *</label>
<input type="text" name="name" required placeholder="Your name" style="width:100%;padding:14px 16px;background:var(--bg);border:1px solid var(--border);border-radius:10px;color:var(--text);font-size:15px">
</div>
<div>
<label style="display:block;font-size:13px;color:var(--text-muted);margin-bottom:6px">Email *</label>
<input type="email" name="email" required placeholder="your@email.com" style="width:100%;padding:14px 16px;background:var(--bg);border:1px solid var(--border);border-radius:10px;color:var(--text);font-size:15px">
</div>
<div>
<label style="display:block;font-size:13px;color:var(--text-muted);margin-bottom:6px">Company</label>
<input type="text" name="company" placeholder="Your company" style="width:100%;padding:14px 16px;background:var(--bg);border:1px solid var(--border);border-radius:10px;color:var(--text);font-size:15px">
</div>
<div>
<label style="display:block;font-size:13px;color:var(--text-muted);margin-bottom:6px">Service Interested In</label>
<select name="service" style="width:100%;padding:14px 16px;background:var(--bg);border:1px solid var(--border);border-radius:10px;color:var(--text);font-size:15px">
<option>Select a service...</option>
<option>AI Brand Audit ($1-2K)</option>
<option>Website Redesign ($5-10K)</option>
<option>Amazon Optimization ($2-5K)</option>
<option>Social Content Pack ($1-3K)</option>
<option>Content Brand Build ($5-10K)</option>
<option>AI Marketing Engine ($5-10K + mo)</option>
<option>Monthly Retainer</option>
<option>Something else</option>
</select>
</div>
<div>
<label style="display:block;font-size:13px;color:var(--text-muted);margin-bottom:6px">Message</label>
<textarea name="message" rows="5" placeholder="Tell us about your project..." style="width:100%;padding:14px 16px;background:var(--bg);border:1px solid var(--border);border-radius:10px;color:var(--text);font-size:15px;resize:vertical"></textarea>
</div>
<button type="submit" class="btn" style="border:none;cursor:pointer;font-size:16px">Send Message →</button>
</form>
</div>
<div>
<div class="svccard" style="margin-bottom:20px;padding:28px">
<div style="font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">Based In</div>
<div style="font-size:20px;font-weight:700;color:var(--green)">Bend, Oregon</div>
<div style="font-size:14px;color:var(--text-muted);margin-top:4px">Serving brands worldwide</div>
</div>
<div class="svccard" style="margin-bottom:20px;padding:28px">
<div style="font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">What We Need From You</div>
<div style="font-size:14px;color:var(--text-muted);line-height:1.6">Just tell us about your brand, your goals, and what challenges you're facing. We'll come back with a plan.</div>
</div>
<div class="svccard" style="padding:28px">
<div style="font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">⚡ Response Time</div>
<div style="font-size:16px;font-weight:600">Within 2 hours during business hours</div>
</div>
</div>
</div>
</div>
</section>